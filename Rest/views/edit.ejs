<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <a href="/posts" class="back-link">← Back to Posts</a>
        <h1>Edit Post</h1>
        
        <div class="post-meta">
            <span class="post-id">Post ID: <%= post.id.substring(0,8) %>...</span>
        </div>
        
        <form action="/posts/<%= post.id %>/edit" method="POST">
            <div class="form-group">
                <input type="text" name="username" value="<%= post.username %>" placeholder="Username" class="form-control" required>
            </div>
            
            <div class="form-group">
                <textarea name="comment" class="form-control" required><%= post.comment %></textarea>
            </div>
            
            <button type="submit" class="btn btn-primary">Update Post</button>
        </form>
    </div>
</body>
</html>