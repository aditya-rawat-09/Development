<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>users</title>
</head>
<body>
    <h1> Users List</h1>
    <br>
    <table border="1">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Edit</th>
        </tr>
        <% for(user of users){ %>
        <tr>
            <td><%= user.id %></td>
            <td><%= user.username %></td>
            <td><%= user.email %></td>
            <td>
                <a href="/users/<%= user.id %>/edit"><button>Edit</button></a>
            </td>
        </tr>
        <% } %>
    </table>
    <br>
    <a href="/"><button>Go Back</button></a>
    
</body>
</html>